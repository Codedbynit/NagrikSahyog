rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidIssue(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'address', 'department', 'description', 'beforeImage', 'status'])
        && data.id is string && data.id.size() <= 50
        && data.name is string && data.name.size() <= 100
        && data.email is string && data.email.size() <= 100
        && data.address is string && data.address.size() <= 500
        && data.department in ['pwd', 'sanitation', 'electricity', 'water']
        && data.description is string && data.description.size() <= 2000
        && data.beforeImage is string && data.beforeImage.size() <= 10000000
        && data.status in ['unassigned', 'in_progress', 'pending', 'resolved'];
    }

    match /test/connection {
      allow read: if true;
    }

    match /issues/{issueId} {
      // Allow single document get operations if valid ID
      allow get: if isValidId(issueId);
      
      // Allow public list for the community dashboard / admin tracking center
      allow list: if true;

      // Allow creating an issue with strict structural validation
      allow create: if isValidId(issueId) 
        && isValidIssue(incoming())
        && incoming().id == issueId;

      // Allow updating issue with validation
      allow update: if isValidId(issueId)
        && isValidIssue(incoming());

      // Allow deleting issue (e.g., admin cleanup)
      allow delete: if isValidId(issueId);
    }
  }
}
